skinparam sequence {
    ActorBackgroundColor    #2E86AB
    ActorBorderColor        #1A5276
    ActorFontColor          white
    ActorFontSize           11
    ActorFontStyle          bold

    ParticipantBackgroundColor #EBF4FB
    ParticipantBorderColor     #2E86AB
    ParticipantFontSize        10
    ParticipantFontStyle       bold

    LifeLineBackgroundColor    #F8FBFF
    LifeLineBorderColor        #AED6F1

    MessageFontSize            9
    MessageFontColor           #1A252F

